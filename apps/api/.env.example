# NestJS (apps/api) 環境変数
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yakuji_dev?schema=public

REDIS_URL=redis://localhost:6379

# 認証（設計書⑦）: access/refresh で別鍵を使用。
# 生成例: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# 課金（Phase7 7-1、設計変更書③ billing）: Stripeダッシュボードで発行。ローカルはダミー値で可。
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_YEARLY=
# Checkout/Portalのsuccess_url・cancel_url・return_url組み立てに使用するフロントエンドのベースURL。
WEB_APP_URL=http://localhost:3000
