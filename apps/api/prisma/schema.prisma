// 医療機器薬事承認支援アプリ Prisma Schema
// 設計書 ④ データベース構成 に準拠。
// Phase 0: マイグレーション基盤の確立（拡張機能のみ）。
// Phase 1: 認証基盤（⑦）として users / organizations / memberships を追加。
// Phase 1: JP法規制データ閲覧（S06/S07）として jurisdictions / regulations / regulation_versions /
//          regulation_sections / regulation_relations を追加。
// Phase 1: JMDN検索（S08/S09）として device_classifications / classification_mappings を追加。
// Phase 2: 学習系（S10-S13）として courses / lessons / quizzes / quiz_questions / user_progress を追加。
// Phase 4: 更新基盤（⑨）として ingestion_jobs を追加。
// Phase 4: 編集ワークフロー（⑧ draft→review→published）として regulation_versions.status を追加。
// Phase 4: 更新通知（S17/S18）として update_subscriptions を追加（設計書④に列定義が無いためユーザー承認済み）。
// Phase 4: 公開時のアプリ内通知生成として notifications を追加（設計書④に列定義が無いためユーザー承認済み）。
// Phase 5: 実務支援（S15/S16、S04プロジェクト概況）として user_projects を追加。
//          設計書のorg_idは必須だが、signup時に組織が自動作成されないため、
//          user_id(所有者)を追加しorganization_idはnullableとする（ユーザー承認済み）。
// Phase 5: 実務支援（S16 チェックリスト・タスク・期限）として project_tasks を追加。
//          設計書は checklist_item_ref で checklists マスタ（届出/認証/承認等の審査項目内容）を参照する
//          構造だが、チェックリストの実内容は薬事の専門知識を要し、AIによる推測実装は誤った規制情報を
//          生むリスクがあるため、checklists マスタは作らずユーザー自由入力のタスク管理とする
//          （ユーザー承認済み）。title を表示用ラベルとして追加し、checklist_item_ref は将来 checklists
//          マスタと連携する際の参照用に nullable で予約する。
// Phase 3: AIチャット基盤（S14「履歴」表示）として ai_chat_sessions / ai_chat_messages を追加。
//          設計書④の主要テーブル一覧に該当テーブルが無いためユーザー承認済みで追加（update_subscriptions等と
//          同方針）。出典(citations)は次コミットのchat API実装時に構造を確定するためjsonbとする。
// Phase 6: 商用化（監査ログ）として audit_logs を追加。設計書④の列定義（actor, action, target, at）を
//          そのまま採用し、種別・IDへの分割等の独自追加は行わない。actor_id は取込パイプライン(⑨)等
//          システム起因の操作を許容するため nullable UUID FK とする。
// Phase 6: 商用化（S21 管理: コンテンツ管理、タグ管理）として tags / taggings を追加。設計書④の
//          「共通」区分に列挙されたタグ機能で、polymorphic（regulation/lesson/classification）設計だが、
//          管理画面から編集可能な対象がlessonのみのため、TaggableTypeは今回LESSONのみを実装する
//          （ユーザー承認済み。regulation/classificationは将来の編集画面実装時に追加）。
// S03（オンボーディング: 職能・関心国選択）として users に profession / interested_jurisdictions /
//          onboarding_completed_at を追加。設計書④の users 列挙（id, email, name, locale, plan,
//          created_at …）に明記は無いが、設計書⑦「職能属性」と設計書⑬の画面遷移（S01-S02-S03-S04、
//          オンボーディング未完了ユーザーはS04等へ進めない）を実現するために必須のためユーザー承認済み
//          で追加。interested_jurisdictions は user_projects.target_jurisdictions と同様、配列カラムで
//          直接保持する（jurisdictions とのjoinテーブルを設けない）。
// Phase 7 (⑦-1 課金基盤): 設計変更書_ライフサイクル管理_SaaS化.md v1.0（2026-07-09ユーザー承認）に基づき、
//          Plan enum に BUSINESS を追加（既存 FREE/PRO/ENTERPRISE 互換）し、subscriptions テーブルを追加。
//          source(STRIPE/COMPLIMENTARY) により Stripe を経由しない社内・特別付与プランを表現する
//          （admin による手動付与、設計変更書⑥「社内利用（無償フル機能）」準拠）。
//          既存の PLAN_PROJECT_LIMITS/PLAN_SUBSCRIPTION_LIMITS の BUSINESS 値は PRO と同一（20件、ユーザー承認済み。
//          設計変更書に明記が無かったため個別確認した）。
// Phase 7 (⑦-2 工程マスタ): 設計変更書_ライフサイクル管理_SaaS化.md ② DB変更 のうち工程マスタ3テーブル
//          （lifecycle_phases / lifecycle_templates / lifecycle_template_steps）を追加。
//          ProjectRoadmap/ProjectRoadmapStep（プロジェクトへの適用・進捗管理）は7-3着手時に追加する
//          （ユーザー承認済み、未使用テーブルを先行して作らない方針）。本コミットはスキーマ追加のみ
//          （API/管理画面/初期マスタデータ投入は別コミット）。
// Phase 7 (⑦-2 工程マスタ 再設計, 2026-07-10): 初期マスタデータ草案（docs/ドラフト_工程マスタ初期データ_JP.md）
//          のユーザーレビューで、単一の LifecycleDeviceCategory enum に「Class」「SaMD/IVD/能動」という異なる軸が
//          混在しており、同じClassでも新医療機器/改良/後発で期間・費用・書類が変わる実態を表現できないと指摘を受け、
//          ユーザー承認のうえ以下へ再設計した（テンプレート未投入・main未反映のタイミングでの変更、影響最小）。
//          - LifecycleDeviceCategory を廃止し、LifecycleFramework（medical device/IVD/combination product、
//            法体系の違いを表現）・LifecycleDeviceClass（Class I-IV/OTHER、frameworkがMEDICAL_DEVICEの場合のみ
//            意味を持つためnullable）・LifecycleProductNovelty（新医療機器/改良/後発）の3軸に分離。
//          - SaMD/能動植込み等の「特性」はenumで固定化せず、既存の tags/taggings（S21）を再利用して表現する
//            （TaggableTypeにLIFECYCLE_TEMPLATEを追加。将来「滅菌済」「AI搭載」等が増えてもスキーマ変更不要にする
//            ため、taggableId FK制約なしの既存パターンをそのまま踏襲）。
//          - procedureType（届出/認証/承認、自由文字列の設計は維持）を approvalRoute へ改称し、「新医療機器/改良/
//            後発」という意味との混同を避ける。
//          - effectiveFrom/effectiveTo（regulation_versionsと同型）を追加。これはアプリ内のpublish/versionの
//            ライフサイクル管理（既存のversion+statusで完結、変更なし）とは別に、「この期間・費用データが妥当と
//            確認できた実世界の期間」を監査目的で保持するための列（PMDA手数料改定等の追跡に必須とユーザー判断）。
// 他ドメインテーブル は各モジュール実装時に追加する（本ファイルへの無断追加はしない）。

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // pgcrypto: UUID生成補助 / pg_trgm: 日本語含むあいまい全文検索 / vector: pgvector（RAG用埋め込み, 設計書⑥⑩）
  extensions = [pgcrypto, pg_trgm, vector]
}

/// システムロール（設計書 ⑦ 準拠）: 運営視点の権限。組織ロール(OrgRole)とは独立して保持する。
enum SystemRole {
  ADMIN
  EDITOR
  USER
}

/// 課金プラン（設計書 ⑦ 準拠、Phase7 ⑦-1 で BUSINESS 追加）: エンタイトルメント層の判定に用いる。
/// BUSINESS は組織向け中間プラン（設計変更書_ライフサイクル管理_SaaS化.md ⑥ プラン分離 準拠）。
enum Plan {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

/// 職能属性（設計書 ⑦「権限ではなく表示パーソナライズに使用（権限モデルを汚さない）」準拠、
/// S03オンボーディングで選択）。
enum Profession {
  REGULATORY
  QA
  SAFETY
  SALES
  DESIGN
  MEDICAL
  ACADEMIC
}

/// 組織種別（設計書 ④ organizations 準拠）
enum OrganizationType {
  MAKER
  MARKETING_HOLDER
  IMPORTER
  ACADEMIC
}

/// 組織内ロール（設計書 ⑦ 準拠）
enum OrgRole {
  ORG_ADMIN
  MEMBER
}

/// ユーザー（設計書 ④ users 準拠）。
/// passwordHash は OAuth のみでサインアップしたユーザーでは null となる
/// （設計書⑦: 認証はメール+パスワード または Google/Microsoft OAuth の2方式のため）。
model User {
  id                     String             @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  email                  String             @unique
  passwordHash           String?            @map("password_hash")
  name                   String
  locale                 String             @default("ja")
  systemRole             SystemRole         @default(USER) @map("system_role")
  plan                   Plan               @default(FREE)
  /// S03オンボーディング未完了の間は null。
  profession             Profession?
  interestedJurisdictions JurisdictionCode[] @default([]) @map("interested_jurisdictions")
  /// S03オンボーディング完了時刻。未完了ユーザーの判定・S04等へのリダイレクトゲートに使用。
  onboardingCompletedAt DateTime?  @map("onboarding_completed_at")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  memberships          Membership[]
  progresses           UserProgress[]
  subscriptions        UpdateSubscription[]
  notifications        Notification[]
  projects             Project[]
  aiChatSessions       AiChatSession[]
  auditLogs            AuditLog[]
  /// 課金サブスクリプション（Phase7 ⑦-1）。既存の`subscriptions`（更新通知購読, UpdateSubscription）と
  /// 名称が衝突するため billingSubscriptions とする。
  billingSubscriptions Subscription[]

  @@map("users")
}

/// 組織（設計書 ④ organizations 準拠）
model Organization {
  id        String           @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  name      String
  type      OrganizationType
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  memberships          Membership[]
  projects             Project[]
  /// 課金サブスクリプション（Phase7 ⑦-1、組織単位のBusiness/Enterpriseプラン）。
  billingSubscriptions Subscription[]

  @@map("organizations")
}

/// ユーザー所属（設計書 ④ memberships 準拠）: ユーザーと組織の中間テーブル（1ユーザーが複数組織に所属可）。
model Membership {
  id             String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  role           OrgRole
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("memberships")
}

/// 法域コード（設計書 ④ jurisdictions 準拠）
enum JurisdictionCode {
  JP
  US
  EU
  UK
  CA
  AU
  CN
  KR
  TW
  SG
}

/// 法規文書種別（設計書 ④ regulations 準拠）
enum RegulationType {
  LAW
  ORDINANCE
  NOTICE
  GUIDANCE
  STANDARD
}

/// 法規文書ステータス（設計書 ④ regulations 準拠）。論理削除のみで表現し、物理削除しない（設計書④ 設計原則）。
enum RegulationStatus {
  ACTIVE
  AMENDED
  REPEALED
}

/// 法規文書間の関係種別（設計書 ④ regulation_relations 準拠）
enum RegulationRelationType {
  AMENDS
  IMPLEMENTS
  REFERS
  SUPERSEDES
}

/// 法域（設計書 ④ jurisdictions 準拠）: 国別スキームを分離するための基点テーブル。
model Jurisdiction {
  id        String           @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  code      JurisdictionCode @unique
  name      String
  authority String
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  regulations           Regulation[]
  deviceClassifications DeviceClassification[]
  updateSubscriptions   UpdateSubscription[]
  lifecycleTemplates    LifecycleTemplate[]

  @@map("jurisdictions")
}

/// 法規文書（設計書 ④⑧ regulations 準拠）。
/// 正: RegulationVersion（原文・版・施行日は不変保持、編集は新版追加のみ）。本テーブルは文書の識別・現況のみを保持する。
model Regulation {
  id             String           @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  jurisdictionId String           @map("jurisdiction_id") @db.Uuid
  type           RegulationType
  /// 国別の文書タイプ差分吸収用（設計書⑧: 例 FDA Guidance, EU MDCG）。スキーマ変更なしで各国拡張するための列。
  subtype        String?
  title          String
  docNumber      String?          @map("doc_number")
  status         RegulationStatus @default(ACTIVE)
  effectiveDate  DateTime?        @map("effective_date") @db.Date
  sourceUrl      String?          @map("source_url")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  jurisdiction  Jurisdiction         @relation(fields: [jurisdictionId], references: [id], onDelete: Restrict)
  versions      RegulationVersion[]
  relationsFrom RegulationRelation[] @relation("RegulationRelationFrom")
  relationsTo   RegulationRelation[] @relation("RegulationRelationTo")

  @@index([jurisdictionId, type, status])
  @@map("regulations")
}

/// 編集ワークフロー状態（設計書⑧「編集ワークフロー: draft → review → published」準拠）。
/// Phase1時点(取込パイプライン未実装)ではこの列が存在せず全版が公開扱いだったため、
/// 既存行との後方互換のためデフォルトをPUBLISHEDとする（Phase4で取込パイプライン導入に伴い追加）。
enum RegulationVersionStatus {
  DRAFT
  REVIEW
  PUBLISHED
}

/// 法規文書バージョン（設計書 ④⑧ regulation_versions 準拠）: 法改正はバージョン行追加で表現し、履歴を不変保持する。
model RegulationVersion {
  id            String                  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  regulationId  String                  @map("regulation_id") @db.Uuid
  versionNo     Int                     @map("version_no")
  publishedAt   DateTime                @map("published_at")
  effectiveFrom DateTime                @map("effective_from") @db.Date
  effectiveTo   DateTime?               @map("effective_to") @db.Date
  fullText      String                  @map("full_text")
  summary       String?
  changeSummary String?                 @map("change_summary")
  /// 編集ワークフロー状態（設計書⑧）。取込パイプライン(⑨)が新版をDRAFTで作成し、editorのレビューを経てPUBLISHEDになる。
  status        RegulationVersionStatus @default(PUBLISHED)
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")

  regulation    Regulation          @relation(fields: [regulationId], references: [id], onDelete: Cascade)
  sections      RegulationSection[]
  notifications Notification[]

  @@unique([regulationId, versionNo])
  @@index([regulationId, status])
  @@map("regulation_versions")
}

/// 条文セクション（設計書 ④ regulation_sections 準拠）: RAG・全文検索の単位。
model RegulationSection {
  id        String                       @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  versionId String                       @map("version_id") @db.Uuid
  /// 条・項・号の階層パス（例: 第23条の2/第1項/第2号）
  path      String
  heading   String
  body      String
  /// 埋め込みベクトル（設計書⑥ RAG用）。Phase 3 のAI機能実装時にWorkerが生成するため、Phase 1時点ではnull。
  embedding Unsupported("vector(1536)")?
  createdAt DateTime                     @default(now()) @map("created_at")
  updatedAt DateTime                     @updatedAt @map("updated_at")

  version RegulationVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, path])
  @@map("regulation_sections")
}

/// 法規文書間の関係（設計書 ④⑧ regulation_relations 準拠）: 例「政令←法律」「通知→改正対象」「基準↔ISO/IEC」。
model RegulationRelation {
  id        String                 @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  fromId    String                 @map("from_id") @db.Uuid
  toId      String                 @map("to_id") @db.Uuid
  relation  RegulationRelationType
  createdAt DateTime               @default(now()) @map("created_at")

  from Regulation @relation("RegulationRelationFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   Regulation @relation("RegulationRelationTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId, relation])
  @@map("regulation_relations")
}

/// 分類スキーム（設計書 ④ device_classifications 準拠）: 国別の機器分類体系を同一テーブルで抽象化する。
enum ClassificationScheme {
  JMDN
  FDA_PRODUCT_CODE
  EMDN
  GMDN
}

/// 機器分類（設計書 ④ device_classifications 準拠、S08/S09）: 国別スキーム(JMDN/FDA_ProductCode/EMDN/GMDN)を
/// 同一テーブルで抽象化する。jurisdictionId は当該コードを所管する法域（例: JMDNはJP）。
model DeviceClassification {
  id             String               @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  jurisdictionId String               @map("jurisdiction_id") @db.Uuid
  scheme         ClassificationScheme
  code           String
  name           String
  /// リスク分類（例: JPクラスI-IV、FDA Class I-III）。国・スキームごとに表記が異なるため自由記述とする。
  class          String?
  definition     String?
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  jurisdiction Jurisdiction            @relation(fields: [jurisdictionId], references: [id], onDelete: Restrict)
  mappingsFrom ClassificationMapping[] @relation("ClassificationMappingFrom")
  mappingsTo   ClassificationMapping[] @relation("ClassificationMappingTo")

  @@unique([jurisdictionId, scheme, code])
  @@index([scheme, code])
  @@map("device_classifications")
}

/// 分類間マッピング（設計書 ④ classification_mappings 準拠）: JMDN↔FDA ProductCode 等の相互参照。
/// 方向性は保持しないため（設計書④「相互参照」）、アプリケーション層では from/to 両方向で検索する。
model ClassificationMapping {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  fromId     String   @map("from_id") @db.Uuid
  toId       String   @map("to_id") @db.Uuid
  /// マッチング信頼度（0.0〜1.0）。手動キュレーションの場合は1.0を設定する運用を想定。
  confidence Float
  createdAt  DateTime @default(now()) @map("created_at")

  from DeviceClassification @relation("ClassificationMappingFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   DeviceClassification @relation("ClassificationMappingTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
  @@map("classification_mappings")
}

/// 学習進捗ステータス（設計書 ④ user_progress 準拠）
enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

/// 学習コース（設計書 ④ courses / ⑫ S10 準拠）: 企画〜市販後・リコールまでの体系カリキュラムの単位。
model Course {
  id          String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  title       String
  description String?
  /// カリキュラム内の表示順（設計書⑫ S10: 体系カリキュラム）。
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  lessons Lesson[]

  @@map("courses")
}

/// レッスン（設計書 ④ lessons / ⑫ S11 準拠）: 本文・図解・関連法令リンクを保持する単位。
/// 関連法令リンクは共通の tags/taggings（設計書④共通、polymorphic: regulation/lesson/classification）実装時に対応する。
model Lesson {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  title     String
  body      String
  /// コース内の表示順。
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course       Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  quizzes      Quiz[]
  userProgress UserProgress[]

  @@unique([courseId, order])
  @@map("lessons")
}

/// クイズ（設計書 ④ quizzes / ⑫ S12 準拠）: レッスンに紐づく理解度確認の単位。
model Quiz {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  lessonId  String   @map("lesson_id") @db.Uuid
  title     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]

  @@map("quizzes")
}

/// クイズ設問（設計書 ④ quiz_questions 準拠）。
model QuizQuestion {
  id              String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  quizId          String   @map("quiz_id") @db.Uuid
  question        String
  /// 選択肢配列（例: [{"id":"a","text":"..."}]）。設計書④ checklists.items と同様、設問形式の多様化に備えjsonbで保持する。
  choices         Json
  correctChoiceId String   @map("correct_choice_id")
  explanation     String?
  /// クイズ内の表示順。
  order           Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, order])
  @@map("quiz_questions")
}

/// ユーザー学習進捗（設計書 ④ user_progress 準拠、⑫ S13）: user_id, lesson_id, status, score, completed_at。
model UserProgress {
  id          String         @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId      String         @map("user_id") @db.Uuid
  lessonId    String         @map("lesson_id") @db.Uuid
  status      ProgressStatus @default(NOT_STARTED)
  score       Int?
  completedAt DateTime?      @map("completed_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("user_progress")
}

/// 取込ジョブ実行ステータス（設計書④ ingestion_jobs 準拠）。
enum IngestionJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

/// 薬事情報更新パイプライン実行履歴（設計書④ ingestion_jobs 準拠、⑨の実行履歴）。
/// source はAdapter識別子の自由記述（例: "PMDA_NOTICES"）とし、各国Adapter追加時にスキーマ変更を
/// 不要にする（設計書④「各国拡張」の方針、device_classifications.schemeと同様の判断）。
/// diffSummary は現時点ではAI要約ではなく、非AIの単純な自動要約（差分行数等）を保持する運用とする
/// （AI機能はPhase3として保留中のため、要ユーザー確認済み）。
model IngestionJob {
  id           String             @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  source       String
  status       IngestionJobStatus @default(PENDING)
  /// 差分要約（非AI、簡易生成）。ジョブ失敗時や差分なしの場合はnull。
  diffSummary  String?            @map("diff_summary")
  /// 失敗時の原因（設計書⑨「失敗時リトライ・ingestion_jobsに監査記録」）。
  errorMessage String?            @map("error_message")
  runAt        DateTime           @map("run_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@index([source, runAt])
  @@map("ingestion_jobs")
}

/// 更新通知の配信頻度（設計書⑤ POST /api/v1/subscriptions、S18「購読国・タイプ・頻度」準拠）。
enum UpdateFrequency {
  REALTIME
  DAILY
  WEEKLY
}

/// 更新通知購読（設計書⑤ POST /api/v1/subscriptions、S17/S18 準拠）。設計書④に本テーブルの列定義は
/// 無いため、S18の画面説明「購読国・タイプ・頻度」に基づきユーザー承認済みで追加する。
/// jurisdictionId/regulationType が null の場合はそれぞれ「全国」「全タイプ」を意味する。
/// 同一ユーザー・同一組み合わせの重複防止は、Postgresの複合UNIQUEがNULLを別値として扱い重複を
/// 検知できないため、DB制約ではなくアプリ層（UpdateSubscriptionRepository.existsForUser）で行う。
model UpdateSubscription {
  id             String          @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId         String          @map("user_id") @db.Uuid
  jurisdictionId String?         @map("jurisdiction_id") @db.Uuid
  regulationType RegulationType? @map("regulation_type")
  frequency      UpdateFrequency
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  jurisdiction Jurisdiction? @relation(fields: [jurisdictionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("update_subscriptions")
}

/// アプリ内通知（設計書⑨「published時: 購読ユーザーへ通知（アプリ内+メール）」準拠、S17）。
/// 設計書④に本テーブルの列定義は無いため、update_subscriptionsと同様にユーザー承認済みで追加する。
/// メール配信は保留中のためアプリ内通知のみを対象とし、既読切替APIは今回のスコープ外（次回検討）。
/// 購読のfrequency(REALTIME/DAILY/WEEKLY)は現時点では無視し、一致する購読者全員に公開時点で即時生成する
/// （メール配信実装時にfrequencyへ応じた配信頻度制御を行う想定、要ユーザー確認済み）。
model Notification {
  id                  String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  regulationVersionId String   @map("regulation_version_id") @db.Uuid
  title               String
  body                String?
  isRead              Boolean  @default(false) @map("is_read")
  createdAt           DateTime @default(now()) @map("created_at")

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  regulationVersion RegulationVersion @relation(fields: [regulationVersionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notifications")
}

/// 実務支援プロジェクト（設計書④ user_projects 準拠、⑫ S15/S16、S04「プロジェクト概況」）。
/// 設計書のorg_idは必須列だが、signup時にOrganizationが自動作成されないため、
/// 所有者を表すuserIdを追加しorganizationIdはnullableとする（組織未所属ユーザーは個人プロジェクトとして
/// organizationId=nullで作成する。ユーザー承認済み）。
model Project {
  id                  String             @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId              String             @map("user_id") @db.Uuid
  organizationId      String?            @map("organization_id") @db.Uuid
  name                String
  /// 対象機器のクラス分類（例: クラスII）。設計書④ device_classifications.classと同様、国により表記が
  /// 異なる自由記述とする。
  deviceClass         String?            @map("device_class")
  targetJurisdictions JurisdictionCode[] @map("target_jurisdictions")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  tasks        ProjectTask[]

  @@index([userId])
  @@map("user_projects")
}

/// タスクステータス（設計書④ project_tasks.status 準拠）。
enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

/// プロジェクトタスク（設計書④ project_tasks 準拠、⑫ S16 チェックリスト・タスク・期限）。
/// 設計書は checklist_item_ref で checklists マスタ（届出/認証/承認等の審査項目内容）を参照する構造だが、
/// チェックリストの実内容は薬事の専門知識を要し、AIによる推測実装は誤った規制情報を生むリスクがあるため、
/// 今回は checklists マスタを作らずユーザー自由入力のタスク管理とする（ユーザー承認済み）。
/// title を必須の表示用ラベルとして追加し、checklistItemRef は将来 checklists マスタと連携する際の
/// 参照用に nullable で予約する。
model ProjectTask {
  id               String     @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  projectId        String     @map("project_id") @db.Uuid
  title            String
  checklistItemRef String?    @map("checklist_item_ref")
  status           TaskStatus @default(TODO)
  dueDate          DateTime?  @map("due_date") @db.Date
  assignee         String?
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_tasks")
}

/// AIチャットメッセージの発言者ロール（設計書⑫ S14「AIチャット」準拠）。
enum AiChatMessageRole {
  USER
  ASSISTANT
}

/// AIチャットセッション（設計書④に列定義は無いためユーザー承認済みで追加、S14「履歴」表示に必要）。
/// 1ユーザーが複数の会話スレッドを持てるようにする（一般的なチャットUXに準拠）。
/// titleの自動生成方法・messages取得API・出典citationsの具体的な構造は、次コミットの
/// chat API実装時に確定する（本コミットはDB基盤のみ）。
model AiChatSession {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiChatMessage[]

  @@index([userId, updatedAt])
  @@map("ai_chat_sessions")
}

/// AIチャットメッセージ（設計書④に列定義は無いためユーザー承認済みで追加、S14「履歴」表示に必要）。
model AiChatMessage {
  id        String            @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  sessionId String            @map("session_id") @db.Uuid
  role      AiChatMessageRole
  content   String
  /// 出典（regulation_sections参照＋版・施行日等、設計書⑥「出典表示」）。構造は次コミットのchat API
  /// 実装時に確定するためjsonbとする。
  citations Json?
  createdAt DateTime          @default(now()) @map("created_at")

  session AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("ai_chat_messages")
}

/// 監査ログ（設計書④ audit_logs 準拠、Phase6 商用化）: actor, action, target, at の4項目を保持する。
/// 追記のみで更新・削除は行わない不変のイベント記録のため updated_at は持たない
/// （regulation_relations / classification_mappings 等と同様の方針）。
/// actorId は取込パイプライン(⑨)等システム起因の操作ではnull（操作主体がユーザーでないため）。
/// target は「対象種別:対象ID」形式の自由記述とする（例: "regulation:0198f2c3-..."）。設計書④は
/// target を単一列として定義しているため、種別・IDを分割した列への変更は行わない。
model AuditLog {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  actorId   String?  @map("actor_id") @db.Uuid
  action    String
  target    String
  createdAt DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

/// タグ付け対象の種別（設計書④ tags/taggings のpolymorphic対象）。管理画面(S21)から編集可能な
/// lessonのみを今回実装する（regulation/classificationは編集画面が未実装のため対象外、ユーザー承認済み）。
/// Phase7 7-2再設計（2026-07-10）: LIFECYCLE_TEMPLATE を追加。SaMD/能動植込み/滅菌済等の「機器特性」を
/// enumで固定化せずタグとして付与するための追加（LifecycleTemplate.characteristicsのような専用列を作らず
/// 既存のtags/taggingsを再利用、将来特性が増えてもスキーマ変更不要にするユーザー承認済みの判断）。
enum TaggableType {
  LESSON
  LIFECYCLE_TEMPLATE
}

/// タグ（設計書④ tags 準拠、⑫ S21「コース・タグ・ユーザー管理」）。
model Tag {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  taggings Tagging[]

  @@map("tags")
}

/// タグ付け（設計書④ taggings 準拠、polymorphic: regulation/lesson/classification）。
/// taggableId は対象種別により参照先テーブルが異なるため、DB外部キー制約は設定できない
/// （整合性はアプリ層で担保する。device_classifications.schemeと同様、各国拡張時にスキーマ変更が
/// 不要な設計方針に合わせた判断）。
model Tagging {
  id           String       @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tagId        String       @map("tag_id") @db.Uuid
  taggableType TaggableType @map("taggable_type")
  taggableId   String       @map("taggable_id") @db.Uuid
  createdAt    DateTime     @default(now()) @map("created_at")

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, taggableType, taggableId])
  @@index([taggableType, taggableId])
  @@map("taggings")
}

/// 課金サブスクリプションの発行元（Phase7 ⑦-1、設計変更書⑥「社内利用（無償フル機能）」準拠）。
/// STRIPE: 通常のStripe課金経由。COMPLIMENTARY: Stripeを通さずadminが組織/ユーザーへ手動付与
/// （自社ドッグフーディング等、実質Enterprise相当を無償付与するためのフラグ）。
enum SubscriptionSource {
  STRIPE
  COMPLIMENTARY
}

/// 課金サブスクリプションの状態（Phase7 ⑦-1）。Stripe Subscription の status を1:1でマッピングする
/// （webhook実装時にそのまま同期するため、Stripe側の値集合と語彙を一致させる）。COMPLIMENTARY発行分は
/// 通常 ACTIVE のみを用いる（admin失効時は CANCELED）。
enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
}

/// 課金サブスクリプション（設計変更書_ライフサイクル管理_SaaS化.md ② DB変更 Subscription 準拠）。
/// userId必須+organizationIdはnullable（user_projectsと同方針: 個人契約と組織契約の両方を1テーブルで表現）。
/// stripeCustomerId/stripeSubscriptionIdはCOMPLIMENTARY発行分ではnull（Postgresのunique indexはnull同士を
/// 重複とみなさないため、複数の複合付与が可能）。plan/statusの実同期ロジックはbilling module実装時に追加する
/// （本コミットはスキーマ追加のみ）。
model Subscription {
  id                   String              @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId               String              @map("user_id") @db.Uuid
  organizationId       String?             @map("organization_id") @db.Uuid
  stripeCustomerId     String?             @unique @map("stripe_customer_id")
  stripeSubscriptionId String?             @unique @map("stripe_subscription_id")
  plan                 Plan
  status               SubscriptionStatus  @default(ACTIVE)
  source               SubscriptionSource  @default(STRIPE)
  currentPeriodEnd     DateTime?           @map("current_period_end")
  seats                Int                 @default(1)
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@map("subscriptions")
}

/// 大工程（設計変更書_ライフサイクル管理_SaaS化.md ② DB変更 LifecyclePhase 準拠、Phase7 7-2）。
/// 企画〜販売終了までの18工程を固定の閉じた集合として列挙する（design docに列挙された全18コード）。
enum LifecyclePhaseCode {
  PLANNING
  MARKET_RESEARCH
  DESIGN
  RISK_ISO14971
  QMS
  TESTING
  REG_STRATEGY
  SUBMISSION
  PMDA_CONSULT
  APPROVAL
  REIMBURSEMENT
  LAUNCH
  SALES
  CHANGE_CONTROL
  COMPLAINT
  CAPA
  RECALL
  DISCONTINUATION
}

/// 規制の法体系区分（Phase7 7-2再設計、2026-07-10ユーザー承認）。医療機器・体外診断用医薬品・コンビネーション
/// プロダクトは薬機法上そもそも根拠条文・分類体系が異なるため、Classとは独立した最上位の軸として持つ。
/// IVDは「医療機器のClass」を持たない（日本のIVDはクラスI-IVの体系を用いないため、下記deviceClassは
/// framework=MEDICAL_DEVICEの場合のみ意味を持つ、nullable）。COMBINATION_PRODUCTは将来拡張用（現時点で
/// 初期マスタデータの投入対象外、enumのみ先行定義）。
enum LifecycleFramework {
  MEDICAL_DEVICE
  IVD
  COMBINATION_PRODUCT
}

/// 医療機器のクラス分類（Phase7 7-2再設計）。旧LifecycleDeviceCategoryからSaMD/IVD/ACTIVEを除去し、
/// Class本来の4区分+OTHERのみに単純化。SaMD/能動植込み等は「特性」であり、下記の通りtags/taggings
/// （TaggableType.LIFECYCLE_TEMPLATE）で表現する（本enumには含めない）。
enum LifecycleDeviceClass {
  CLASS_I
  CLASS_II
  CLASS_III
  CLASS_IV
  OTHER
}

/// 新規性区分（Phase7 7-2再設計）。新医療機器/改良医療機器/後発医療機器はPMDAの審査期間・手数料が
/// 大きく異なる別軸のため独立させた（旧procedureType自由文字列に「届出/認証/承認」と混在させていたのを分離）。
/// 届出（審査を伴わない）等、概念自体が当てはまらない手続きではnull。
enum LifecycleProductNovelty {
  NEW
  MODIFIED
  GENERIC
}

/// 工程マスタの公開状態（設計変更書② DB変更「status(draft/published)」準拠）。regulation_versionsの
/// DRAFT/REVIEW/PUBLISHEDと異なり2状態のみ（design docの記載通り）。校閲ワークフロー自体はS20と同様
/// editor/adminのCRUD+publish操作で行う（③API追加「CRUD /admin/lifecycle-templates、S20と同じ
/// draft→publishフロー」準拠、状態遷移の粒度は本enumの2状態に対応させる）。
enum LifecycleTemplateStatus {
  DRAFT
  PUBLISHED
}

/// 大工程マスタ（設計変更書② DB変更 LifecyclePhase 準拠、Phase7 7-2）。18工程の固定リスト。
/// nameは表示用日本語ラベル、orderは表示順（企画=1〜販売終了=18を想定、実データ投入は別コミット）。
model LifecyclePhase {
  id        String             @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  code      LifecyclePhaseCode @unique
  name      String
  order     Int
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  steps LifecycleTemplateStep[]

  @@map("lifecycle_phases")
}

/// 工程マスタ・テンプレート本体（設計変更書② DB変更 LifecycleTemplate 準拠、Phase7 7-2、2026-07-10再設計）。
/// regulationと同じ「不変版管理+status」原則（design doc記載）をこの1テーブルで表現する
/// （regulation/regulation_versionsのような親子分割はせず、versionを直接列として持つ）。
/// approvalRoute（旧procedureType）はJP(届出/認証/承認)/US(510k)/EU(CE)等、国により語彙が大きく異なり
/// 設計書も「届出/認証/承認/510k/CE…」と非網羅的に記載しているため、regulation.subtypeと同様に自由文字列
/// とする（enum化して将来の国追加のたびにスキーマ変更が必要になる事態を避ける）。
/// deviceClass/productNoveltyはframework=MEDICAL_DEVICE以外や届出等の一部手続きで意味を持たないためnullable。
/// SaMD/能動植込み等の「特性」は本モデルに列を持たず、tags/taggings（TaggableType.LIFECYCLE_TEMPLATE、id経由）
/// で表現する（本モデル側にリレーションは定義しない。taggableIdはFK制約なしのアプリ層整合性、既存Tagging同様）。
/// effectiveFrom/effectiveToは「このテンプレートの期間・費用データが妥当と確認できた実世界の期間」の監査用
/// （PMDA手数料改定等の追跡が目的で、version/statusによるpublishライフサイクル管理とは独立した概念）。
model LifecycleTemplate {
  id             String                    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  jurisdictionId String                    @map("jurisdiction_id") @db.Uuid
  framework      LifecycleFramework        @default(MEDICAL_DEVICE)
  deviceClass    LifecycleDeviceClass?     @map("device_class")
  productNovelty LifecycleProductNovelty?  @map("product_novelty")
  approvalRoute  String                    @map("approval_route")
  status         LifecycleTemplateStatus   @default(DRAFT)
  version        Int                       @default(1)
  effectiveFrom  DateTime                  @map("effective_from") @db.Date
  effectiveTo    DateTime?                 @map("effective_to") @db.Date
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")

  jurisdiction Jurisdiction            @relation(fields: [jurisdictionId], references: [id], onDelete: Restrict)
  steps        LifecycleTemplateStep[]

  @@index([jurisdictionId, framework, deviceClass, approvalRoute, status], name: "lifecycle_templates_filter_idx")
  @@map("lifecycle_templates")
}

/// 工程マスタの個別工程（設計変更書② DB変更 LifecycleTemplateStep 準拠、Phase7 7-2）。
/// durationMin/MaxDays・costMin/MaxJpyは「概算レンジ」（設計変更書④AI設計「免責: 費用・期間は概算
/// レンジ・参考値」準拠）。relatedRegulationIdsはregulationsへのFK配列だが、Postgresの配列列には外部キー
/// 制約を張れないためアプリケーション層で整合性を担保する（既存のuser_projects.target_jurisdictions等と
/// 同じ設計判断）。sourceRefsは設計書④AI設計の「根拠必須」原則に基づき必須列とする（空配列は許容、
/// 実データ投入時のバリデーションはAPI実装時に追加）。
model LifecycleTemplateStep {
  id                   String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  templateId           String   @map("template_id") @db.Uuid
  phaseId              String   @map("phase_id") @db.Uuid
  name                 String
  order                Int
  durationMinDays      Int?     @map("duration_min_days")
  durationMaxDays      Int?     @map("duration_max_days")
  costMinJpy           Int?     @map("cost_min_jpy")
  costMaxJpy           Int?     @map("cost_max_jpy")
  requiredDocuments    Json     @map("required_documents")
  requiredTests        Json     @map("required_tests")
  relatedRegulationIds String[] @map("related_regulation_ids")
  pmdaResourceUrls     Json     @map("pmda_resource_urls")
  notes                String?
  sourceRefs           Json     @map("source_refs")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  template LifecycleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  phase    LifecyclePhase    @relation(fields: [phaseId], references: [id], onDelete: Restrict)

  @@index([templateId])
  @@index([phaseId])
  @@map("lifecycle_template_steps")
}
